[sqlfluff]
dialect = bigquery
templater = dbt
max_line_length = 100
# ST06 (order columns by complexity) conflicts with semantic column
# grouping in contracted marts, where order is part of the interface.
exclude_rules = structure.column_order

[sqlfluff:templater:dbt]
project_dir = dbt
profiles_dir = dbt
profile = floodit_analytics
target = dev

[sqlfluff:indentation]
tab_space_size = 4

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = lower

[sqlfluff:rules:capitalisation.identifiers]
extended_capitalisation_policy = snake
# CP02's snake regex rejects metric suffixes like retention_d7, which are
# the project-standard names (see CLAUDE.md testing examples).
ignore_words_regex = ^(is_)?(retained|retention)_d[0-9]+$

[sqlfluff:rules:capitalisation.functions]
extended_capitalisation_policy = lower

[sqlfluff:rules:capitalisation.literals]
capitalisation_policy = lower

[sqlfluff:rules:capitalisation.types]
extended_capitalisation_policy = lower

[sqlfluff:rules:ambiguous.column_references]
group_by_and_order_by_style = explicit

[sqlfluff:rules:aliasing.table]
aliasing = explicit

[sqlfluff:rules:aliasing.column]
aliasing = explicit
